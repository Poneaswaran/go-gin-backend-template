# Database type: sqlite | postgres | mysql
DB_TYPE=sqlite

# PostgreSQL connection string (used when DB_TYPE=postgres)
POSTGRES_DSN=host=localhost user=postgres password=postgres dbname=appdb port=5432 sslmode=disable TimeZone=UTC

# MySQL connection string (used when DB_TYPE=mysql)
MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/appdb?charset=utf8mb4&parseTime=True&loc=Local

# SQLite DSN (used when DB_TYPE=sqlite)
SQLITE_DSN=test.db?_pragma=busy_timeout(5000)
